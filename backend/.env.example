# Environment configuration for AI PDF Bot Backend

# Environment: "local" for SQLite, "gcp" for Google Cloud SQL
ENVIRONMENT=local

# ============== LOCAL SQLITE CONFIGURATION ==============
# Path to SQLite database (relative to backend directory)
DB_PATH=./data/ai_pdf_bot.db

# ============== GCP CLOUD SQL CONFIGURATION ==============
# Uncomment and configure these for GCP Cloud SQL deployment
# DB_USER=ai_pdf_bot_user
# DB_PASSWORD=your_database_password
# DB_NAME=ai_pdf_bot
# DB_HOST=127.0.0.1       # only used when NOT using socket (CLOUD_SQL_CONNECTION_NAME)
# DB_PORT=3306

# Cloud Run connects to Cloud SQL via Unix socket – set this to enable socket mode:
# CLOUD_SQL_CONNECTION_NAME=your-project:us-central1:ai-pdf-bot-db

# ============== SQLALCHEMY CONFIGURATION ==============
# Set to true to enable SQLAlchemy query logging
SQLALCHEMY_ECHO=False

# ============== JWT CONFIGURATION ==============
# Secret key for JWT token signing – REQUIRED, no default. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here
# Algorithm for JWT encoding/decoding
ALGORITHM=HS256
# Access token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Connection pool recycle time (in seconds) - important for Cloud SQL
SQLALCHEMY_POOL_RECYCLE=3600

# ============== APPLICATION CONFIGURATION ==============
# Set to development or production
APP_ENV=development
DEBUG=True

# ============== LLM CONFIGURATION ==============
# Groq keys tried in order (key 1 → key 2 → key 3).
# If all three hit the rate-limit, the request falls back to OpenAI gpt-4o-mini.
GROQ_API_KEY_1=your-groq-api-key-1-here
GROQ_API_KEY_2=your-groq-api-key-2-here
GROQ_API_KEY_3=your-groq-api-key-3-here
OPENAI_API_KEY=your-openai-api-key-here
LLM_PROVIDER=groq
GROQ_MODEL=llama3-8b-8192
OPENAI_MODEL=gpt-4o-mini

# ============== CORS CONFIGURATION ==============
ALLOWED_ORIGINS=http://localhost:3000

# ============== LIVE WEB VERIFICATION ==============
# Minimum confidence (0-100) required for a web result to be used in chat live_mode.
WEB_MIN_CONFIDENCE=75
# If true, only high-trust domains (gov/edu/major institutions) are used.
WEB_TRUSTED_ONLY=true

# ============== RESEND EMAIL CONFIGURATION ==============
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=onboarding@resend.dev
FRONTEND_URL=http://localhost:3000

# ============== GOOGLE AUTH CONFIGURATION ==============
GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com