# Environment configuration for AI PDF Bot Backend

# Environment: "local" for SQLite, "gcp" for Google Cloud SQL
ENVIRONMENT=local

# ============== LOCAL SQLITE CONFIGURATION ==============
# Path to SQLite database (relative to backend directory)
DB_PATH=./data/ai_pdf_bot.db

# ============== GCP CLOUD SQL CONFIGURATION ==============
# Uncomment and configure these for GCP Cloud SQL deployment
# DB_USER=root
# DB_PASSWORD=your_database_password
# DB_HOST=your-project:your-region:instance-name
# DB_PORT=3306
# DB_NAME=ai_pdf_bot

# ============== SQLALCHEMY CONFIGURATION ==============
# Set to true to enable SQLAlchemy query logging
SQLALCHEMY_ECHO=False

# ============== JWT CONFIGURATION ==============
# Secret key for JWT token signing (change this in production!)
SECRET_KEY=akash-vamsi-project-1
# Algorithm for JWT encoding/decoding
ALGORITHM=HS256
# Access token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Connection pool recycle time (in seconds) - important for Cloud SQL
SQLALCHEMY_POOL_RECYCLE=3600

# ============== APPLICATION CONFIGURATION ==============
# Set to development or production
APP_ENV=development
DEBUG=True